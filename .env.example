# Ollama (required for local inference)
OLLAMA_HOST=http://localhost:11434

# HuggingFace (optional, for model downloads)
HF_API_KEY=your_key_here

# OpenRouter API (optional, not used in main experiments)
OPENROUTER_API_KEY=your_key_here

# Groq API (optional, not used in main experiments)
GROQ_API_KEY=your_key_here

# Google / Gemini API (optional, not used in main experiments)
GOOGLE_API_KEY=your_key_here
GEMINI_API_KEY=your_key_here
